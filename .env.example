# Copy this to .env and fill in your Arbox MEMBER credentials.
# `.env` is gitignored and never committed.

# Required for login / re-login when the access token expires.
# These are the same email + password you use in the Arbox Members app /
# on site.arboxapp.com — NOT the gym-owner panel credentials.
ARBOX_EMAIL=you@example.com
ARBOX_PASSWORD=replace-me

# Filled in automatically by `arbox auth login`. Do not edit by hand.
# Access token is a JWT (~1h lifetime). When it expires the CLI will
# silently re-login using the credentials above.
ARBOX_TOKEN=
ARBOX_REFRESH_TOKEN=

# Optional, discovered after login. Your gym's box id and the box-location
# id you train at. `arbox auth login` will try to auto-discover both.
ARBOX_BOX_ID=
ARBOX_LOCATIONS_BOX_ID=

# Required only if your Arbox account belongs to more than one gym.
# Case-insensitive substring of the box or location name (e.g. "CrossFit
# Downtown"). Overrides `gym:` in config.yaml. Discovery re-runs every call
# when set, so a stale ARBOX_LOCATIONS_BOX_ID is auto-corrected.
# ARBOX_GYM=

# Override `timezone:` in config.yaml. Useful when reusing the same image
# for users in different countries.
# ARBOX_TIMEZONE=Asia/Jerusalem

# Override the Arbox API base URL. Default is the member backend:
#   https://apiappv2.arboxapp.com
# Only change this if Arbox moves the host.
# ARBOX_BASE_URL=https://apiappv2.arboxapp.com

# Optional — Telegram outbound notifications (daemon only; no webhook).
# Run:  go run ./cmd/arbox telegram discover   (after /start in the bot)
# to print your TELEGRAM_CHAT_ID, then set both here (or in the host's secret store).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional — merged weekly `days:` overlay (Telegram /setup → /setupdone).
# Defaults next to .env (so ~/arbox/data/user_plan.yaml on Oracle, ./user_plan.yaml locally).
# ARBOX_USER_PLAN=
# ARBOX_SETUP_SESSION=

# ─── OPTIONAL — LLM-facing HTTP API ────────────────────────────────────────
# ⚠️ This section is OPT-IN. Leave both vars unset (the default) and the
# HTTP server will NOT start — zero LLM surface, zero attack surface. The
# daemon + Telegram bot keep working exactly the same.
#
# Only set these AFTER the booker has been working reliably for a week AND
# you have read docs/API.md + docs/NANOBOT.md in full. Any LLM/MCP client
# holding the admin token can book / cancel / pause (the ?confirm=1 gate
# helps but it's not a substitute for trusting the client).
#
# Generate strong tokens with `openssl rand -hex 32`. Read = GET only;
# Admin = everything (still gated by ?confirm=1 on mutations).
# ARBOX_API_READ_TOKEN=
# ARBOX_API_ADMIN_TOKEN=

# Optional — bind address for the HTTP API. Default is 127.0.0.1:8080
# (loopback-only) because nanobot runs on the same Oracle VM as this
# daemon, as the same ubuntu user — so loopback is the most secure path
# that still works. Override to ":8080" to listen on all interfaces if
# nanobot is in a separate container or on another host.
# ARBOX_HTTP_ADDR=127.0.0.1:8080

# Optional — audit log location for API mutations. Defaults to
# ./audit.jsonl next to the .env file (so /home/ubuntu/arbox/data/audit.jsonl
# on Oracle). One JSON line per mutation. 10 MB rotation, one .1 backup.
# ARBOX_AUDIT_LOG=
